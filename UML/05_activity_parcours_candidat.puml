@startuml
title Diagramme d'activités – Parcours Candidat (CFC)

start

:Consulter le catalogue des formations;

if (Formation publiée ?) then (Oui)
    :Consulter détails de la formation;

    if (Période d'inscription ouverte ?) then (Oui)
        :Se préinscrire;
        :Remplir et soumettre le dossier;

        :Dossier enregistré;
        :Attendre la décision de l'administration;

        if (Décision Admin ?) then (Acceptée)
            :Notification d'acceptation;
            :Inscription finale;
        else (Refusée)
            :Notification de refus;
        endif

    else (Non)
        :Message "Inscriptions fermées";
    endif

else (Non)
    :Formation non disponible;
endif

stop
@enduml